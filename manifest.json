{
  "manifest_version": 3,
  "name": "DataSidekick",
  "description": "Editor visual para LocalStorage e SessionStorage com JSON tree, busca, importação e exportação.",
  "version": "0.1.3",
  "minimum_chrome_version": "114",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open DataSidekick"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}